 <h1>Create New List</h1>

    <!-- We use a standard ID for the form, but we handle submit with JS -->
    <form id="listForm">
        
        <!-- PART 1: LIST DATA -->
        <div class="form-group">
            <label>List Name</label>
            <input type="text" id="listName" required placeholder="e.g., Weekend Chores">
        </div>

      
        <hr>

        <!-- PART 2: TASK DATA -->
        <h3>Tasks</h3>
        <div id="tasksContainer">
            <!-- Default First Task -->
            <div class="task-row">
                <label>Task Name</label>
                <input type="text" class="task-name" required placeholder="Task Name">
                <input type="text" class="task-desc" placeholder="Task Description">
            </div>
        </div>

        <button type="button" class="btn-add" onclick="addTaskField()">+ Add Another Task</button>
        <br><br>
        <button type="submit" class="btn-save">Save Payload</button>
    </form>

    <script>
        // 1. Add new visual fields
        function addTaskField() {
            const container = document.getElementById('tasksContainer');
            const div = document.createElement('div');
            div.className = 'task-row';
            div.innerHTML = `
                <label>Task Name</label>
                <input type="text" class="task-name" required placeholder="Task Name">
                <input type="text" class="task-desc" placeholder="Task Description">
            `;
            container.appendChild(div);
        }

        // 2. Handle Submit and Build Payload
        document.getElementById('listForm').addEventListener('submit', async (e) => {
            e.preventDefault(); // Stop the standard form submit

            // A. GRAB LIST DATA
            const listName = document.getElementById('listName').value;

            // B. GRAB TASK DATA (Loop through rows)
            const tasksArray = [];
            const taskRows = document.querySelectorAll('.task-row');
            
            taskRows.forEach(row => {
                const nameVal = row.querySelector('.task-name').value;
                const descVal = row.querySelector('.task-desc').value;
                
                // Only add if name is not empty
                if(nameVal.trim() !== "") {
                    tasksArray.push({
                        name: nameVal,
                        description: descVal
                    });
                }
            });

            // C. CONSTRUCT THE FINAL PAYLOAD
            // This object matches your Sequelize associations exactly
            const payload = {
                name: listName,
                Tasks: tasksArray 
            };

            console.log("Payload being sent:", payload);

            // D. SEND VIA FETCH
            try {
                const response = await fetch('/addlist', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json' // Important: Tells server this is JSON
                    },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                
                if(response.ok) {
                    alert('Saved! Check console for response.');
                    console.log('Server Response:', result);
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                console.error('Fetch error:', error);
                alert('Failed to send request');
            }
        });
    </script>